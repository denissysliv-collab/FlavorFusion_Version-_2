# Порт сервера
PORT=5000

# PostgreSQL подключение
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flavorfusion
DB_USER=postgres
DB_PASSWORD=your_password

# JWT секрет (в production использовать сложный рандомный ключ)
JWT_SECRET=super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Режим (development / production)
NODE_ENV=development
