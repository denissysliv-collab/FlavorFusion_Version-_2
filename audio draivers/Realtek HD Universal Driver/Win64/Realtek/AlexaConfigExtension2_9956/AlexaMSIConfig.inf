Provider    = %Realtek%
ExtensionId = {7f7901fa-ea73-4a95-bada-55bf89f37009}
DriverVer = 02/23/2026, 1.0.9956.1
CatalogFile = AlexaConfig.cat
PnpLockDown=1

[SourceDisksNames]
222 = %DiskId1%

[SourceDisksFiles]
RTKSpeechPP2_2.dll=222

[DestinationDirs]
